[Unit]
Description=He Thong May Bom Thong Minh Nhom 08
After=network.target

[Service]
ExecStartPre=-/sbin/route add default gw 192.168.7.1
ExecStartPre=/bin/sh -c 'echo "nameserver 8.8.8.8" > /etc/resolv.conf'
ExecStart=/home/debian/smart_pump_project/app/smart_pump_app
WorkingDirectory=/home/debian/smart_pump_project/app
StandardOutput=inherit
StandardError=inherit
Restart=always
User=root

[Install]
WantedBy=multi-user.target